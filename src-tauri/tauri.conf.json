{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "GolemianAutoclick",
    "version": "3.0.0"
  },
  "build": {
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": false,
      "identifier": "com.r127.golemianautoclick"
    },
    "windows": [
      {
        "title": "Golemian Autoclick",
        "width": 500,
        "height": 450,
        "resizable": false,
        "center": true
      }
    ]
  }
}
